# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in ONE provider's key (only if you leave
# stub mode). Never commit ".env" — this ".env.example" is the committed,
# secret-free template.
# ---------------------------------------------------------------------------

# === Tool layer mode: stub | local | mcp ===================================
#   stub  -> canned, fully offline, deterministic. No keys, no network. (default)
#   local -> real public data (web search + page fetch) + a local file write.
#            Works with just an LLM key; zero MCP setup.
#   mcp   -> the MCP learning path: fetch + filesystem via real MCP servers
#            (needs uv/uvx and Node/npx on PATH). Search stays local.
TOOL_MODE=stub

# === Web search provider (local/mcp modes) =================================
#   ddgs    -> DuckDuckGo, free, NO key (default; weak + rate-limited).
#   tavily  -> free tier ~1000/mo, AI-focused   (needs TAVILY_API_KEY)
#   brave   -> free tier ~2000/mo               (needs BRAVE_API_KEY)
#   serpapi -> real Google results (optional)   (needs SERPAPI_API_KEY)
# If the chosen provider errors or its key is missing, it falls back to ddgs.
# Egypt locale is applied per provider (gl=eg / country=EG / country=egypt).
SEARCH_PROVIDER=ddgs
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPAPI_API_KEY=

# === LLM provider (default for every role) =================================
#   groq | gemini | ollama | stub
#   stub -> keyless deterministic fake model (used automatically with --mode stub)
LLM_PROVIDER=groq

# --- Per-role overrides (the SLM lever) ------------------------------------
# The supervisor only routes, so it gets a STRONGER model; the specialists do
# narrow work, so they run on a small/cheap SLM. Override provider and/or model
# per role. (Sensible defaults live in config.py if you leave these unset.)
# SUPERVISOR_PROVIDER=groq
# SUPERVISOR_MODEL=llama-3.3-70b-versatile
# WORKER_PROVIDER=groq
# WORKER_MODEL=llama-3.1-8b-instant
# WRITER_PROVIDER=groq
# WRITER_MODEL=llama-3.1-8b-instant

# --- Provider keys (only the provider you use needs one) -------------------
GROQ_API_KEY=          # free tier: https://console.groq.com
GOOGLE_API_KEY=        # free tier: https://aistudio.google.com

# === Safety / behaviour knobs (optional; defaults in config.py) ============
# Hard cap on supervisor routing turns, so a misbehaving router can't loop.
MAX_SUPERVISOR_TURNS=12
# Per-HTTP-request timeout (seconds) for local-mode fetch/search.
HTTP_TIMEOUT=15
# Optional read-only safety control: comma-separated domain allowlist for the
# local fetch tool. Empty => not enforced. e.g. ALLOWED_FETCH_DOMAINS=example.com,sec.gov
ALLOWED_FETCH_DOMAINS=

# === Observability (OPTIONAL, zero code) ===================================
# LangChain/LangGraph auto-trace to LangSmith when these are set. The offline
# eval and tests work fine without them. Free tier: https://smith.langchain.com
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=diligencedesk
